# Copy to .env to override defaults. All values have sensible defaults in
# docker-compose.yml, so .env is optional.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shipdb_phase1

# --- AI chat agent (read-only DB role, see db/init/03_agent_ro_role.sh) ---
AGENT_DB_PASSWORD=agent_ro_pw

# --- AI chat agent v1 (Stage 4b LLM SQL draft, Stage 7 v1 synthesis) ---
# Optional: without a usable provider, v1's two LLM stages degrade gracefully
# to v0's clarifying/template answers — the 6 known intents are unaffected
# either way. AGENT_LLM_PROVIDER picks which one is active; both implement
# the same interface (llm_client.py), so switching is just this one value.
AGENT_LLM_PROVIDER=anthropic
# anthropic: cloud, needs a real key + account credit
ANTHROPIC_API_KEY=
AGENT_LLM_MODEL=claude-haiku-4-5-20251001
# gemini: cloud, free tier available — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
AGENT_GEMINI_MODEL=gemini-3-flash-preview
# ollama: local, needs Ollama running on the host and the model already
# pulled (`ollama pull llama3.1`) with tool/function-calling support.
AGENT_OLLAMA_MODEL=llama3.1
AGENT_OLLAMA_HOST=http://host.docker.internal:11434

# --- Seeder (dataset size). Defaults match the reference dataset (25k). ---
# Lower these for a faster first boot while developing, e.g. 2000 / 200.
SEED_SHIPMENTS=25000
SEED_CUSTOMERS=800
SEED_RANDOM_SEED=42

# --- Frontend: Google Maps JavaScript API key ---
# Powers the journey map on the shipment detail drawer (markers + flight/truck
# route legs). Create one at https://console.cloud.google.com/google/maps-apis
# with the "Maps JavaScript API" enabled. Baked into the static build at
# image-build time, so `docker compose up --build frontend` after changing it.
VITE_GOOGLE_MAPS_API_KEY=
